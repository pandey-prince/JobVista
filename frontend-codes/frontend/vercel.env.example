# Copy these to Vercel → Project Settings → Environment Variables (Production)
# Root directory must be: frontend-codes/frontend
#
# IMPORTANT: every VITE_*_API_END_POINT must be a full https:// URL to your backend.
# Never commit real production hosts here — put them in local .env / Vercel only.
# Never use placeholders like "...admin" — Vite bakes them into the bundle
# and the browser will call https://www.joblelo.online/...admin (SPA HTML).

VITE_SITE_URL=https://www.joblelo.online
VITE_GOOGLE_CLIENT_ID=
# Optional single base (used only when a specific VITE_*_API_END_POINT is missing)
VITE_API_BASE_URL=https://YOUR_BACKEND_HOST/api/v1
VITE_USER_API_END_POINT=https://YOUR_BACKEND_HOST/api/v1/user
VITE_JOB_API_END_POINT=https://YOUR_BACKEND_HOST/api/v1/job
VITE_APPLICATION_API_END_POINT=https://YOUR_BACKEND_HOST/api/v1/application
VITE_COMPANY_API_END_POINT=https://YOUR_BACKEND_HOST/api/v1/company
VITE_CHATBOT_API_END_POINT=https://YOUR_BACKEND_HOST/api/v1/chatbot
VITE_SCRAPED_JOB_API_END_POINT=https://YOUR_BACKEND_HOST/api/v1/scraped-jobs
VITE_CAREER_SOURCE_API_END_POINT=https://YOUR_BACKEND_HOST/api/v1/career-sources
VITE_STATS_API_END_POINT=https://YOUR_BACKEND_HOST/api/v1/stats
VITE_SAVED_JOBS_API_END_POINT=https://YOUR_BACKEND_HOST/api/v1/saved-jobs
VITE_DISMISSED_JOBS_API_END_POINT=https://YOUR_BACKEND_HOST/api/v1/dismissed-jobs
VITE_ALERTS_API_END_POINT=https://YOUR_BACKEND_HOST/api/v1/alerts
VITE_TRACKED_APPLICATIONS_API_END_POINT=https://YOUR_BACKEND_HOST/api/v1/tracked-applications
VITE_ADMIN_API_END_POINT=https://YOUR_BACKEND_HOST/api/v1/admin
