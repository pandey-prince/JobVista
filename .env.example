# Copy to .env in project root for docker compose
# For Render: set these in Dashboard → jobvista-backend → Environment

MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/jobvista
SECRET_KEY=your-super-secret-jwt-key-change-me
FRONTEND_URL=https://job-vista-eta.vercel.app
SCRAPE_ENABLED=true
SCRAPE_ON_BOOT=false
SCRAPE_CRON_SCHEDULE=0 */6 * * *
MAX_UPSERTS_PER_SOURCE=0
SCRAPE_DELAY_MS=1500
LINK_CHECK_ENABLED=true
LINK_CHECK_CRON=0 3 * * *
LINK_CHECK_BATCH_SIZE=50
LINK_CHECK_DELAY_MS=1000
LINK_CHECK_FAIL_THRESHOLD=3
LINK_CHECK_TIMEOUT_MS=10000
LINK_CHECK_AFTER_SYNC=true
LINK_CHECK_POST_SYNC_BATCH=30
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
SKIP_PUPPETEER_SCRAPERS=true
PUPPETEER_WAIT_MS=5000
PUPPETEER_DELAY_MS=3000
SMARTDREAMERS_MAX_PAGES=5

# Optional — JobMate chatbot
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Email alerts (Resend) — https://resend.com
RESEND_API_KEY=
EMAIL_FROM=JobVista <onboarding@resend.dev>
# Daily digest cron (IST 8 PM = 14:30 UTC)
ALERT_DIGEST_CRON=30 14 * * *

# File uploads — Cloudinary (recommended for production) or local /uploads fallback
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
API_BASE_URL=https://jobvista-ahek.onrender.com

# Optional — trigger priority Puppeteer GitHub Actions when users submit career pages
GITHUB_WORKFLOW_DISPATCH_TOKEN=
GITHUB_REPO=pandey-prince/JobVista

# Ops admin (run: npm run seed:admin)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FULLNAME=JobVista Admin
ADMIN_PHONE=9000000000
