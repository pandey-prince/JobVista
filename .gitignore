# ==============================
# Node Modules
# ==============================
node_modules/
*/node_modules/

# ==============================
# Environment Files
# ==============================
.env
.env.*
!.env.example

# ==============================
# Logs
# ==============================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==============================
# OS Files
# ==============================
.DS_Store
Thumbs.db

# ==============================
# Build Folders
# ==============================
dist/
build/
coverage/

# ==============================
# Vite / React
# ==============================
.vite/
*.local

# ==============================
# Render / Deployment
# ==============================
.render
.vercel

# ==============================
# Local git hooks (never push to remote)
# ==============================
.githooks/

# ==============================
# IDE Files
# ==============================
.vscode/
.idea/

# ==============================
# Temporary Files
# ==============================
tmp/
temp/

# ==============================
# Uploads (local fallback when Cloudinary is not configured)
# ==============================
backend/uploads/*
!backend/uploads/.gitkeep

