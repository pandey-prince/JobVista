#!/bin/sh
# Strip Cursor agent attribution from commit messages (local hook).
sed -i '/cursoragent@cursor\.com/d' "$1" 2>/dev/null || sed -i '' '/cursoragent@cursor\.com/d' "$1"
sed -i '/Co-authored-by: Cursor/d' "$1" 2>/dev/null || sed -i '' '/Co-authored-by: Cursor/d' "$1"
sed -i '/Made-with: Cursor/d' "$1" 2>/dev/null || sed -i '' '/Made-with: Cursor/d' "$1"
